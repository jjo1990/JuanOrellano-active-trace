# Database
DATABASE_URL=postgresql+asyncpg://trace:trace@localhost:5432/trace

# Security
SECRET_KEY=change-me-to-a-random-string-of-at-least-32-chars
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=15

# OpenTelemetry (optional — leave empty to disable OTLP export)
OTEL_SERVICE_NAME=activia-trace
OTEL_EXPORTER_OTLP_ENDPOINT=
